# ── AWS Credentials ────────────────────────────────────────────────────────────
# Option A (local dev / CI): explicit key pair
# Option B (EC2):            leave blank and attach an IAM role to the instance
#                            — boto3 picks up the role automatically
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=eu-west-1

# ── S3 Model Storage ───────────────────────────────────────────────────────────
# Set this to enable S3 model loading in api/app.py.
# Leave blank to use local models/ directory instead.
S3_BUCKET_NAME=crm-churn-intelligence
MODEL_S3_KEY=models/final_model.pkl
FEATURE_COLS_S3_KEY=models/feature_columns.json

# ── API ────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
